  "overlap": {
    "overlaps_with": [],
    "overlap_type": "none",
    "overlap_note": "ATM withdrawals are cash-out events, not payments. They are NOT double-counted with any other payment category. A consumer withdrawing cash at an ATM creates one ATM transaction; when they later spend that cash, it is an untracked cash payment — not captured in cards, wallets, or bank transfers.",
    "relationship_to_cards": "ATM withdrawals use card rails for authentication (card inserted/tapped, PIN verified) but the transaction is a cash disbursement, not a purchase. Card network statistics typically exclude ATM withdrawals from purchase transaction counts but include them in total card volume by value."
  },
